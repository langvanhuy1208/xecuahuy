<?xml version="1.0"?>
<robot name="xecuahuy">

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.12479 -0.03636 -0.05" rpy="0 0 0" />
      <mass value="10.0" /> 
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://xecuahuy/meshes/base_link.STL" /></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://xecuahuy/meshes/base_link.STL" /></geometry>
    </collision>
  </link>

  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <inertial><mass value="0.1"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
    <visual><geometry><cylinder radius="0.03" length="0.02"/></geometry></visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.165352103475908 -0.0363599065007527 0.0569265444399953" rpy="0 0 -1.5707963267949"/> 
  </joint>

  <link name="camera_link">
    <inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
    <visual><geometry><box size="0.02 0.05 0.02"/></geometry></visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.0622846103497731 -0.0364342033367859 0.0534265444399953" rpy="0 0 3.14159"/>
  </joint>

  <link name="left_link">
    <inertial><mass value="0.5"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><mesh filename="package://xecuahuy/meshes/left_link.STL"/></geometry></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.57 0"/><geometry><cylinder radius="0.03" length="0.02"/></geometry></collision>
  </link>
  <joint name="left_joint" type="continuous">
    <origin xyz="0.12485 0.03365 -0.00507" rpy="0 0 -1.57"/><parent link="base_link"/><child link="left_link"/><axis xyz="-1 0 0"/>
  </joint>

  <link name="right_link">
    <inertial><mass value="0.5"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><mesh filename="package://xecuahuy/meshes/right_link.STL"/></geometry></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.57 0"/><geometry><cylinder radius="0.03" length="0.02"/></geometry></collision>
  </link>
  <joint name="right_joint" type="continuous">
    <origin xyz="0.12485 -0.10635 -0.00507" rpy="0 0 -1.57"/><parent link="base_link"/><child link="right_link"/><axis xyz="-1 0 0"/>
  </joint>

  <link name="noi_link">
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><mesh filename="package://xecuahuy/meshes/noi_link.STL"/></geometry></visual>
    <collision><geometry><mesh filename="package://xecuahuy/meshes/noi_link.STL"/></geometry></collision>
  </link>
  <joint name="noi_joint" type="fixed"><origin xyz="0.11035 -0.03635 0.11393" rpy="0 0 -1.57"/><parent link="base_link"/><child link="noi_link"/></joint>

  <link name="prismatic_link">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><mesh filename="package://xecuahuy/meshes/prismatic_link.STL"/></geometry></visual>
    <collision><geometry><mesh filename="package://xecuahuy/meshes/prismatic_link.STL"/></geometry></collision>
  </link>
  <joint name="prismatic_joint" type="prismatic"><origin xyz="0.11035 -0.03635 0.11492" rpy="0 0 -1.57"/><parent link="base_link"/><child link="prismatic_link"/><axis xyz="0 0 1"/><limit lower="-0.04" upper="0.00" effort="100" velocity="1.0"/></joint>

  <link name="rotary_link">
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    <visual><geometry><mesh filename="package://xecuahuy/meshes/rotary_link.STL"/></geometry></visual>
    <collision><geometry><mesh filename="package://xecuahuy/meshes/rotary_link.STL"/></geometry></collision>
  </link>
  <joint name="rotary_joint" type="revolute"><origin xyz="0.01 0 0.084" rpy="1.57 0 1.57"/><parent link="prismatic_link"/><child link="rotary_link"/><axis xyz="0 0 1"/><limit lower="-1.57" upper="1.57" effort="10" velocity="1"/></joint>


  <gazebo reference="lidar_link">
    <sensor name="lidar" type="ray">
      <always_on>true</always_on><visualize>true</visualize><update_rate>10</update_rate>
      <ray><scan><horizontal><samples>360</samples><min_angle>0.0</min_angle><max_angle>6.28</max_angle></horizontal></scan>
      <range><min>0.12</min><max>12.0</max></range></ray>
      <plugin name="lidar_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type><frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <update_rate>30.0</update_rate><visualize>true</visualize>
      <camera name="head"><horizontal_fov>1.396</horizontal_fov><image><width>800</width><height>600</height><format>R8G8B8</format></image></camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros><remapping>~/image_raw:=image_raw</remapping></ros><frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
  <sensor name="imu_sensor" type="imu">
    <always_on>true</always_on>
    <update_rate>100</update_rate>
    <visualize>false</visualize>
    <imu>
      <angular_velocity>
        <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
        <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
        <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
      </angular_velocity>
      <linear_acceleration>
        <x><noise type="gaussian"><mean>0</mean><stddev>0.065</stddev></noise></x>
        <y><noise type="gaussian"><mean>0</mean><stddev>0.065</stddev></noise></y>
        <z><noise type="gaussian"><mean>0</mean><stddev>0.065</stddev></noise></z>
      </linear_acceleration>
    </imu>
    <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
      <ros>
        <remapping>~/out:=imu</remapping>
      </ros>
      <initial_orientation_as_reference>false</initial_orientation_as_reference>
    </plugin>
  </sensor>
</gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware><plugin>gazebo_ros2_control/GazeboSystem</plugin></hardware>
    <joint name="left_joint">
      <command_interface name="velocity"><param name="min">-10</param><param name="max">10</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="right_joint">
      <command_interface name="velocity"><param name="min">-10</param><param name="max">10</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="prismatic_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="rotary_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
  </ros2_control>
<gazebo>
  <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
    <parameters>$(find xecuahuy)/config/controllers.yaml</parameters>
  </plugin>
</gazebo>
</robot>
